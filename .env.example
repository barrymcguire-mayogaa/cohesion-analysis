# COHESION Analysis Environment Configuration
# Copy this file to .env.local (local development) or set these in Netlify
# DO NOT commit actual secrets - this file documents what's required

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Your Supabase project URL
# Get from: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (safe to expose, read-only by RLS)
# Get from: Supabase Dashboard → Settings → API → Project API keys → anon
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (PROTECT THIS! Never expose to browser)
# Get from: Supabase Dashboard → Settings → API → Project API keys → service_role
# Only needed for Netlify Functions
# Set this in Netlify: Site settings → Build & deploy → Environment → Edit variables
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# NETLIFY IDENTITY CONFIGURATION
# ============================================================================

# Netlify Identity endpoint (auto-configured by Netlify)
# Format: https://your-site.netlify.app/.netlify/identity
NETLIFY_IDENTITY_URL=https://your-site.netlify.app/.netlify/identity

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# LOCAL DEVELOPMENT:
# 1. Copy this file to .env.local
# 2. Fill in the actual values from your Supabase & Netlify dashboards
# 3. The browser will load SUPABASE_URL and SUPABASE_KEY
# 4. Netlify Functions automatically have access to all env vars
#
# NETLIFY DEPLOYMENT:
# 1. Do NOT commit secrets to GitHub
# 2. Set environment variables in Netlify dashboard:
#    - Site settings → Build & deploy → Environment → Edit variables
#    - Add all variables above
# 3. Netlify Functions can access these via process.env
# 4. Browser code can access via window.env (if configured in build)
#
# SECURITY:
# - SUPABASE_SERVICE_ROLE_KEY must NEVER be exposed to browser
# - Only use in Netlify Functions (server-side, protected)
# - RLS policies in Supabase prevent anon key from writing
# - Admin operations go through Netlify Functions, not direct browser writes
#
